{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/", "destination": "/configure.html" },
    { "source": "/configure", "destination": "/configure.html" },
    { "source": "/:user/configure", "destination": "/configure.html" },
    { "source": "/(.*)", "destination": "/api/$1" }
  ]
}
