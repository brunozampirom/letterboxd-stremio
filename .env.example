# Port for the local server (used by `yarn dev` and Docker).
PORT=7777

# How long, in minutes, to cache scraped Letterboxd data before re-fetching.
# Higher values reduce load on Letterboxd and improve response time.
CACHE_TTL_MINUTES=60

# User-Agent string sent to Letterboxd. Identify your fork so site admins
# can reach you if there's a problem. The default points to upstream.
USER_AGENT=letterboxd-stremio/0.1 (+https://github.com/brunozampirom/letterboxd-stremio)

# Per-IP rate limit (requests per minute). Only enforced when Upstash Redis
# env vars are present (see below). Leave at defaults unless you need to
# tune for traffic patterns.
RATELIMIT_CATALOG_PER_MIN=20
RATELIMIT_DEFAULT_PER_MIN=60

# Upstash Redis credentials. Auto-injected on Vercel by the Marketplace
# integration. For local development, run `npx vercel env pull .env.local`
# to pull them. If absent, the addon falls back to in-memory cache (no
# persistence, no rate limiting).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Admin token. When set, gates the /admin/probe diagnostic endpoint
# (which fetches arbitrary Letterboxd paths via the configured fetcher
# and reports status, byte size, and Cloudflare challenge detection).
# Without this token set, /admin/probe returns 404. Generate with:
#   openssl rand -hex 32
# ADMIN_TOKEN=

# TMDB API read access token (v4 auth). When set, enables the
# "Letterboxd Recommended" catalog: pulls recently rated films from
# the user's RSS feed and asks TMDB for similar / recommended titles.
# Get a token at https://www.themoviedb.org/settings/api (free).
# Without a token set, the catalog is omitted from the manifest and
# everything else continues to work normally.
# TMDB_READ_TOKEN=
